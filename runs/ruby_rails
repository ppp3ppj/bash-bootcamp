#!/usr/bin/env bash

# Check if mise is installed, skip if not
if ! command -v mise &>/dev/null; then
  echo "mise is not installed. Skipping ruby installation."
  exit 0
fi

# Check if ruby is already installed via mise, skip if so
if mise list ruby 2>/dev/null | grep -q ruby; then
  echo "ruby is already installed. Skipping."
  exit 0
fi

mise use --global ruby@latest
gem install rails
